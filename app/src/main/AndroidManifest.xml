<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".KairosApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kairos">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Kairos">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name="com.getaltair.kairos.notification.receiver.ReminderAlarmReceiver"
            android:exported="false" />

        <receiver
            android:name="com.getaltair.kairos.notification.receiver.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.getaltair.kairos.ACTION_COMPLETE_HABIT" />
                <action android:name="com.getaltair.kairos.ACTION_SNOOZE_HABIT" />
                <action android:name="com.getaltair.kairos.ACTION_SKIP_HABIT" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="com.getaltair.kairos.notification.receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <service
            android:name=".wear.WearDataSyncService"
            android:exported="false" />

        <service
            android:name=".wear.WearMessageListenerService"
            android:exported="true"
            android:permission="com.google.android.wearable.BIND_LISTENER">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:host="*"
                    android:pathPrefix="/kairos/message"
                    android:scheme="wear" />
            </intent-filter>
        </service>

        <receiver
            android:name="com.getaltair.kairos.feature.widget.KairosWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/kairos_widget_info" />
        </receiver>
    </application>

</manifest>
